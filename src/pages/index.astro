---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectIcon from '../components/ProjectIcon.astro';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Swift Everywhere">
  <section class="hero">
    <h1>Swift, <em>everywhere</em>.</h1>
    <p class="lede">
      Swift Everywhere is a community-driven effort to make Swift a great
      language for every platform — Android, server, embedded, WebAssembly,
      and Windows. Browse the projects, read the blog, and get involved.
    </p>
    <p>
      <a class="button" href="/projects/">Explore the projects</a>
      <a class="button button-secondary" href="/blog/">Read the blog</a>
    </p>
  </section>

  <section>
    <h2>Projects</h2>
    <p class="muted">
      Each Swift Everywhere project tackles one platform. Pick one to see
      its landing page and the related blog posts.
    </p>
    <div class="card-grid">
      {projects.map((project) => (
        <a
          class="card card-link project-card"
          href={`/projects/${project.id}/`}
          style={`--project-tint: ${project.data.tint}`}
        >
          <ProjectIcon
            icon={project.data.icon}
            tint={project.data.tint}
            literal={project.data.iconLiteral}
            size="2rem"
          />
          <h3>{project.data.title}</h3>
          <p>{project.data.tagline}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2>Latest from the blog</h2>
    {recentPosts.length === 0 ? (
      <p class="muted">No posts yet. Check back soon.</p>
    ) : (
      <ul class="post-list">
        {recentPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              {post.data.tags.length > 0 && (
                <span> · {post.data.tags.map((t) => <span class="tag">{t}</span>)}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    )}
    <p><a href="/blog/">All posts &rarr;</a></p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 1rem;
    text-align: center;
  }
  .hero h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }
  .hero h1 em {
    color: var(--color-accent);
    font-style: normal;
  }
  .lede {
    max-width: 38rem;
    margin: 0 auto 1.5rem;
    font-size: 1.15rem;
    color: var(--color-muted);
  }
  .button-secondary {
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    margin-left: 0.5rem;
  }
  .button-secondary:hover {
    background: var(--color-accent);
    color: #fff;
  }
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .project-card h3 {
    margin: 0.25rem 0 0;
  }
  .project-card:hover {
    border-color: var(--project-tint);
  }
</style>
