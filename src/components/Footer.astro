---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="inner">
    <p>
      &copy; {year} Swift Everywhere. Built with
      <a href="https://astro.build">Astro</a>. Source on
      <a href="https://github.com/swift-everywhere/swift-everywhere.github.io">GitHub</a>.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    padding: 1.5rem 1.25rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }
</style>
