---
interface Props {
  icon: string;
  tint: string;
  literal?: boolean;
  size?: string; // any CSS length
  label?: string;
  class?: string;
}

const {
  icon,
  tint,
  literal = false,
  size = '1.75rem',
  label,
  class: className,
} = Astro.props;

const url = `/icons/projects/${icon}.svg`;

// Tinted (default): render as a <span> whose background is painted with
// the project tint and whose mask-image is the SVG. Works for any
// single-color glyph.
//
// Literal: render as an <img> so the SVG's intrinsic colors are
// preserved. Use this for multi-color brand logos.
const tintedStyle = [
  `--icon-url: url('${url}')`,
  `--project-tint: ${tint}`,
  `--icon-size: ${size}`,
].join('; ');

const literalStyle = `--icon-size: ${size}`;
---

{literal ? (
  <img
    src={url}
    alt={label ?? ''}
    aria-hidden={label ? undefined : 'true'}
    class:list={['project-icon', 'project-icon-literal', className]}
    style={literalStyle}
  />
) : (
  <span
    class:list={['project-icon', className]}
    role={label ? 'img' : undefined}
    aria-label={label}
    aria-hidden={label ? undefined : 'true'}
    style={tintedStyle}
  />
)}

<style>
  .project-icon {
    display: inline-block;
    flex-shrink: 0;
    width: var(--icon-size);
    height: var(--icon-size);
    vertical-align: middle;
  }
  span.project-icon {
    background-color: var(--project-tint);
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }
  .project-icon-literal {
    object-fit: contain;
  }
</style>
